# Auth panel — CHANGE FOR PRODUCTION
ADMIN_EMAIL=admin@illuminato.com
ADMIN_PASSWORD=admin
JWT_SECRET=your-jwt-secret-here

# PostgreSQL — CHANGE FOR PRODUCTION
POSTGRES_USER=bottoo
POSTGRES_PASSWORD=bottoo123
POSTGRES_DB=bottoo
DATABASE_URL=postgresql://bottoo:bottoo123@localhost:5433/bottoo

# EvolutionAPI — CHANGE FOR PRODUCTION
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-evolution-api-key

# Anthropic — REQUIRED
ANTHROPIC_API_KEY=your-anthropic-api-key

# Timezone (IANA format)
TIMEZONE=America/Argentina/Buenos_Aires

# Operational limits (optional, sensible defaults)
MAX_TOOL_ITERATIONS=10
AGENT_TIMEOUT_MS=120000
TOOL_TIMEOUT_MS=60000

# Google Calendar OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Webhook base URL — use host.docker.internal for local Docker setups
# (localhost won't work because Evolution API runs inside a container)
WEBHOOK_BASE_URL=http://host.docker.internal:3001

# CORS origin — must match frontend URL
CORS_ORIGIN=http://localhost:3000

# Webhook security (optional, recommended for production)
# Set a shared secret between Evolution API and this backend
WEBHOOK_SECRET=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
